// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String
  passwordHash  String
  createdAt     DateTime          @default(now())
  preferences   UserPreferences?
  recordings    Recording[]
}

model UserPreferences {
  id                  String      @id @default(cuid())
  userId              String      @unique
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  difficulty          Difficulty  @default(EASY)
  backingTrackVolume  Float       @default(0.6)
  samplesVolume       Float       @default(0.8)
  backingTrackMuted   Boolean     @default(false)
  samplesMuted        Boolean     @default(false)
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Recording {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  baseFilename      String    // Filename without extension; audio and event log differ by extension
  durationSeconds   Float
  fileSizeBytes     Int
  audioMimeType     String    // For audio file extension; event log is always application/json
  createdAt         DateTime  @default(now())
}